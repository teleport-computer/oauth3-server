# Owner secret — extension uses it to sync jars and to mint scoped tokens.
# Generate: openssl rand -hex 32
OWNER_SECRET=

# Seals the cookie vault at rest (AES-GCM). 32-byte hex: openssl rand -hex 32.
# Dev: a throwaway value here. Prod: the daemon derives + injects this per-app
# (dstack GetKey → HKDF, via the isolated-container argv) — NOT committed.
SEAL_KEY=

# Background poller cadence (minutes). Default 30.
POLL_INTERVAL_MIN=30

PORT=3000
DATA_DIR=./data
